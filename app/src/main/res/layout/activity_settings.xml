<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dark_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

        <!-- ========== CONNEXION ========== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connection"
            android:textColor="@color/purple_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="@string/server_url"
            android:textColorHint="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editServerUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textUri" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="@string/api_token"
            android:textColorHint="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editApiToken"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="@string/assistant_name"
            android:textColorHint="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editAssistantName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ========== SESSION ========== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/session_label"
            android:textColor="@color/purple_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleSessionMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSessionSeparate"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/session_separate"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSessionShared"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/session_shared"
                android:textColor="@color/text_primary" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <TextView
            android:id="@+id/txtSessionDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/session_shared_desc"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutCustomSessionKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:hint="@string/session_key_hint"
            android:textColorHint="@color/text_secondary"
            app:placeholderText="agent:main"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editCustomSessionKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/txtSessionKeyInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/session_key_info"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <!-- ========== RECONNAISSANCE VOCALE (STT) ========== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Speech Recognition"
            android:textColor="@color/purple_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleSttProvider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSttWhisper"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Whisper"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSttAndroid"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Android"
                android:textColor="@color/text_primary" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/layoutOpenaiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:hint="OpenAI API Key (Whisper)"
            android:textColorHint="@color/text_secondary">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editOpenaiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- ========== SYNTHESE VOCALE (TTS) ========== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Text-to-Speech"
            android:textColor="@color/purple_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleTtsProvider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginBottom="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTtsElevenLabs"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ElevenLabs"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTtsAndroid"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Android"
                android:textColor="@color/text_primary" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <LinearLayout
            android:id="@+id/layoutElevenLabsFields"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="ElevenLabs API Key"
                android:textColorHint="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editElevenLabsKey"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:hint="Voice ID ElevenLabs"
                android:textColorHint="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editElevenLabsVoice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchAutoTts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/auto_tts"
            android:textColor="@color/text_primary"
            android:checked="true"
            android:layout_marginBottom="24dp" />

        <!-- ========== AFFICHAGE ========== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Display"
            android:textColor="@color/purple_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/theme_label"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleTheme"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThemeDark"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/theme_dark"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThemeLight"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/theme_light"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnThemeSystem"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/theme_system"
                android:textColor="@color/text_primary" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <!-- Language -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/language_label"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButtonToggleGroup
            android:id="@+id/toggleLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLangSystem"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/language_system"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLangEn"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/language_english"
                android:textColor="@color/text_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLangFr"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/language_french"
                android:textColor="@color/text_primary" />
        </com.google.android.material.button.MaterialButtonToggleGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/font_size"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/txtFontSizeValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15sp"
                android:textColor="@color/purple_light"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <SeekBar
            android:id="@+id/seekFontSize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:min="12"
            android:max="24"
            android:progress="15"
            android:progressTint="@color/purple_primary"
            android:thumbTint="@color/purple_primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtFontPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Text size preview"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:layout_marginBottom="32dp" />

        <!-- ========== FEATURES ========== -->

            <!-- Security -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/biometric_title"
                android:textColor="@color/purple_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchBiometric"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/biometric_lock"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/biometric_lock_desc"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="24dp" />

            <!-- Backup -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/backup_title"
                android:textColor="@color/purple_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackupExport"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/backup_export"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackupImport"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/backup_import"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp" />

            <!-- Accent color -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/accent_color_title"
                android:textColor="@color/purple_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <!-- Notifications -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notifications_title"
                android:textColor="@color/purple_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchNotifications"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/notifications_switch"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/notifications_desc"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="32dp">

                <View
                    android:id="@+id/colorCircle0"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/color_circle"
                    android:layout_marginHorizontal="6dp" />
                <View
                    android:id="@+id/colorCircle1"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/color_circle"
                    android:layout_marginHorizontal="6dp" />
                <View
                    android:id="@+id/colorCircle2"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/color_circle"
                    android:layout_marginHorizontal="6dp" />
                <View
                    android:id="@+id/colorCircle3"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/color_circle"
                    android:layout_marginHorizontal="6dp" />
                <View
                    android:id="@+id/colorCircle4"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/color_circle"
                    android:layout_marginHorizontal="6dp" />
                <View
                    android:id="@+id/colorCircle5"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/color_circle"
                    android:layout_marginHorizontal="6dp" />
                <View
                    android:id="@+id/colorCircle6"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/color_circle"
                    android:layout_marginHorizontal="6dp" />
                <View
                    android:id="@+id/colorCircle7"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/color_circle"
                    android:layout_marginHorizontal="6dp" />
            </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save"
            android:backgroundTint="@color/purple_primary" />

    </LinearLayout>
</ScrollView>
