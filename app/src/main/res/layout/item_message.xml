<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="2dp">

    <LinearLayout
        android:id="@+id/bubbleContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:maxWidth="300dp"
        android:paddingHorizontal="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="6dp"
        android:layout_marginHorizontal="8dp">

        <!-- Sender hidden (Google Messages style) -->
        <TextView
            android:id="@+id/txtSender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:visibility="gone"
            android:layout_marginBottom="2dp" />

        <!-- Reply quote -->
        <LinearLayout
            android:id="@+id/replyContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginBottom="6dp"
            android:background="@drawable/reply_quote_bg"
            android:padding="8dp">

            <View
                android:id="@+id/replyBar"
                android:layout_width="3dp"
                android:layout_height="match_parent"
                android:background="@color/purple_light"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/txtReplyContent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:maxLines="2"
                android:ellipsize="end"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/mediaContainer"
            android:layout_width="240dp"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:layout_marginBottom="6dp"
            android:clipChildren="true">

            <ImageView
                android:id="@+id/imgMedia"
                android:layout_width="240dp"
                android:layout_height="wrap_content"
                android:maxHeight="300dp"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true" />

            <ImageView
                android:id="@+id/iconPlayOverlay"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_media_play"
                android:visibility="gone" />
        </FrameLayout>

        <TextView
            android:id="@+id/txtContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:lineSpacingExtra="2dp" />

        <!-- Reaction emoji -->
        <TextView
            android:id="@+id/txtReaction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:visibility="gone"
            android:layout_marginTop="2dp" />

        <!-- Footer: timestamp + retry + regenerate, aligned end -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="end"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/txtTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="@color/text_secondary" />

            <ImageButton
                android:id="@+id/btnRetry"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_rotate"
                android:contentDescription="Retry"
                android:visibility="gone"
                android:scaleType="centerInside"
                android:padding="2dp"
                android:layout_marginStart="6dp"
                app:tint="#FFEF4444" />

            <ImageButton
                android:id="@+id/btnRegenerate"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_rotate"
                android:contentDescription="Regenerate"
                android:visibility="gone"
                android:scaleType="centerInside"
                android:padding="2dp"
                android:layout_marginStart="6dp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
